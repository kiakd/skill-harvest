# Copy this file to .env (which is gitignored) and fill in.
# config.py auto-loads .env on startup. Real environment variables always win.
# NEVER put your real API key in this example file — only in .env.

# --- Option A: local Gemma 4 via Ollama (default, free, offline) ---
#   ollama pull gemma4:e4b
# SH_LLM_BASE_URL=http://localhost:11434/v1
# SH_LLM_MODEL=gemma4:e4b
# SH_LLM_API_KEY=ollama

# --- Option B: DeepSeek (cloud, needs internet + paid key) ---
# SH_LLM_BASE_URL=https://api.deepseek.com/v1
# SH_LLM_MODEL=deepseek-chat
# SH_LLM_API_KEY=sk-replace-with-your-deepseek-key
